# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Backend Environment Template (PERN-Store)
# ══════════════════════════════════════════════════════════════════════════════

# ── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Application Port ─────────────────────────────────────────────────────────
# The API listens on this port INSIDE the container
PORT=9000

# ── PostgreSQL Connection ────────────────────────────────────────────────────
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=your_database_name
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_SSL=false

# ── JWT Configuration ────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS Allowed Origins ────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost,http://localhost:80

# ── Frontend Base URL ───────────────────────────────────────────────────────
CLIENT_URL=http://localhost:80

# ── Mail Server Settings ────────────────────────────────────────────────────
SMTP_FROM=noreply@example.com
SMTP_USER=your_smtp_username
MFA_ENCRYPTION_KEY=your_base64_encoded_32_byte_key

# ── Stripe Secret Key ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key

# ── Razorpay Keys ───────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Google OAuth2.0 — Sign-in ───────────────────────────────────────────────
OAUTH_CLIENT_ID=your_google_oauth_client_id
OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
OAUTH_REFRESH_TOKEN=your_google_oauth_refresh_token

# ── Google OAuth2.0 — Email Sending ─────────────────────────────────────────
CLIENT_ID=your_google_client_id
CLIENT_SECRET=your_google_client_secret
REFRESH_TOKEN=your_google_refresh_token

# ── Logging Level ────────────────────────────────────────────────────────────
LOG_LEVEL=info
